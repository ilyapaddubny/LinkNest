{
  "info": {
    "name": "LinkNest API",
    "description": "API collection for LinkNest bookmark management system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "inherit"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Bookmarks",
      "item": [
        {
          "name": "Get Bookmarks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/bookmarks?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookmarks"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "tag",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "cursor",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "isPublic",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Bookmark",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"title\": \"Example Site\",\n  \"description\": \"An example website\",\n  \"tags\": [\"web\", \"example\"],\n  \"isPublic\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookmarks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookmarks"]
            }
          },
          "response": []
        },
        {
          "name": "Get Bookmark by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/bookmarks/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookmarks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "bookmark_id_here"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Bookmark",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"description\": \"Updated description\",\n  \"tags\": [\"updated\", \"bookmark\"],\n  \"isPublic\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookmarks/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookmarks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "bookmark_id_here"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Bookmark",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/bookmarks/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookmarks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "bookmark_id_here"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "Get Tags",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tags?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tags"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Bookmarks by Tag",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tags/:tagName/bookmarks?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tags", ":tagName", "bookmarks"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "cursor",
                  "value": "",
                  "disabled": true
                }
              ],
              "variable": [
                {
                  "key": "tagName",
                  "value": "web"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Public Routes",
      "item": [
        {
          "name": "Get Public Bookmarks by User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/public/:username?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", ":username"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "tag",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "cursor",
                  "value": "",
                  "disabled": true
                }
              ],
              "variable": [
                {
                  "key": "username",
                  "value": "user@example.com"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ]
}
