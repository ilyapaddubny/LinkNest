#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run type checking
echo "Running type checking..."
npm run type-check || {
    echo "Type checking failed. Please fix TypeScript errors before committing."
    exit 1
}

# Run linting
echo "Running ESLint..."
npm run lint || {
    echo "Linting failed. Please fix ESLint errors before committing."
    exit 1
}

# Run Prettier check
echo "Checking code formatting..."
npm run format:check || {
    echo "Code formatting issues found. Please run 'npm run format' before committing."
    exit 1
}

echo "All pre-commit checks passed!"
